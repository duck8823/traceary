{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "traceary-session-start",
            "type": "command",
            "command": "bash \"${extensionPath}/scripts/traceary-session.sh\" gemini start",
            "timeout": 5000,
            "description": "Start a Traceary session"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "traceary-session-end",
            "type": "command",
            "command": "bash \"${extensionPath}/scripts/traceary-session.sh\" gemini end",
            "timeout": 5000,
            "description": "Finish a Traceary session"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "name": "traceary-audit",
            "type": "command",
            "command": "bash \"${extensionPath}/scripts/traceary-audit.sh\" gemini",
            "timeout": 5000,
            "description": "Record shell command audits in Traceary"
          }
        ]
      }
    ]
  }
}
